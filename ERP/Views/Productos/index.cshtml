@model IEnumerable<ERP.Models.Producto>

<h2>Productos</h2>

<a asp-action="Crear" class="btn btn-success mb-3">
Nuevo Producto
</a>

<table class="table table-bordered">

<thead>
<tr>
<th>ID</th>
<th>Nombre</th>
<th>Precio</th>
<th>Stock</th>
<th>Acciones</th>
</tr>
</thead>

<tbody>

@foreach (var p in Model)
{
<tr>

<td>@p.IdProducto</td>
<td>@p.Nombre</td>
<td>@p.Precio</td>
<td>@p.Stock</td>

<td>

<a asp-action="Editar"
asp-route-id="@p.IdProducto"
class="btn btn-warning btn-sm">
Editar
</a>

<a asp-action="Eliminar"
asp-route-id="@p.IdProducto"
class="btn btn-danger btn-sm">
Eliminar
</a>

</td>

</tr>
}

</tbody>

</table>