@using Microsoft.AspNetCore.Http
@{
    var username = Context.Session.GetString("Username");
    var rol = Context.Session.GetString("Rol");
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ERP Concesionario</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Dashboard" asp-action="Index">ERP Concesionario</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    @if (!string.IsNullOrEmpty(username))
                    {
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                            </li>

                            @if (rol == "Admin" || rol == "Ventas")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Clientes" asp-action="Index">Clientes</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Ventas" asp-action="Index">Ventas</a>
                                </li>
                            }

                            @if (rol == "Admin" || rol == "Compras")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Proveedores" asp-action="Index">Proveedores</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Compras" asp-action="Index">Compras</a>
                                </li>
                            }

                            @if (rol == "Admin" || rol == "Inventario")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Productos" asp-action="Index">Productos</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Vehiculos" asp-action="Index">Vehículos</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Inventario" asp-action="Index">Inventario</a>
                                </li>
                            }

                            @if (rol == "Admin" || rol == "RRHH")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Empleados" asp-action="Index">Empleados</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Nominas" asp-action="Index">Nómina</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="RRHH" asp-action="Index">RRHH</a>
                                </li>
                            }

                            @if (rol == "Admin")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Usuarios" asp-action="Index">Usuarios</a>
                                </li>
                            }
                        </ul>

                        <div class="d-flex align-items-center gap-2">
                            <span class="text-white small">Usuario: @username | Rol: @rol</span>
                            <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-light btn-sm">Inicio</a>
                            <a asp-controller="Account" asp-action="Logout" class="btn btn-warning btn-sm">Salir</a>
                        </div>
                    }
                    else
                    {
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0"></ul>

                        <div class="d-flex align-items-center gap-2">
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-sm">Iniciar sesión</a>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>

    <main class="container mt-4">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>