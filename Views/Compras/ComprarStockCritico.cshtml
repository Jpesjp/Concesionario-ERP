@model ERPConcesionario.Models.CompraStockCriticoFormViewModel

@{
    ViewData["Title"] = "Comprar Producto";
    var proveedores = ViewBag.Proveedores as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-1">Comprar Producto</h1>
        <p class="text-muted mb-0">Recepcion inmediata para corregir una alerta de stock critico.</p>
    </div>
    <a asp-controller="Inventario" asp-action="StockCritico" class="btn btn-secondary">Volver</a>
</div>

@if (!proveedores.Any())
{
    <div class="alert alert-danger">
        No hay proveedores activos. Registra o activa un proveedor antes de comprar.
    </div>
}

<form asp-action="ComprarStockCritico" method="post" class="card border-0 shadow-sm">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input asp-for="IdInventarioProducto" type="hidden" />
        <input asp-for="IdProducto" type="hidden" />
        <input asp-for="CodigoProducto" type="hidden" />
        <input asp-for="NombreProducto" type="hidden" />
        <input asp-for="StockActual" type="hidden" />
        <input asp-for="StockMinimo" type="hidden" />
        <input asp-for="StockMaximo" type="hidden" />
        <input asp-for="IdAlmacen" type="hidden" />
        <input asp-for="IdUbicacion" type="hidden" />
        <input asp-for="Almacen" type="hidden" />
        <input asp-for="Ubicacion" type="hidden" />

        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Codigo</div>
                    <strong>@Model.CodigoProducto</strong>
                </div>
            </div>
            <div class="col-md-5">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Producto</div>
                    <strong>@Model.NombreProducto</strong>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Stock actual</div>
                    <strong>@Model.StockActual</strong>
                </div>
            </div>
            <div class="col-md-2">
                <div class="border rounded p-3 h-100">
                    <div class="text-muted small">Stock minimo</div>
                    <strong>@Model.StockMinimo</strong>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="IdProveedor" class="form-label">Proveedor</label>
                <select asp-for="IdProveedor" asp-items="proveedores" class="form-select">
                    <option value="">Seleccione un proveedor</option>
                </select>
                <span asp-validation-for="IdProveedor" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Cantidad" class="form-label">Cantidad</label>
                <input asp-for="Cantidad" class="form-control" min="1" type="number" />
                <span asp-validation-for="Cantidad" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="CostoUnitario" class="form-label">Costo unitario</label>
                <input asp-for="CostoUnitario" class="form-control" min="0" step="0.01" type="number" />
                <span asp-validation-for="CostoUnitario" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="Observaciones" class="form-label">Observaciones</label>
                <textarea asp-for="Observaciones" class="form-control" rows="3"></textarea>
            </div>
        </div>
    </div>
    <div class="card-footer bg-white d-flex justify-content-end gap-2">
        <a asp-controller="Inventario" asp-action="StockCritico" class="btn btn-outline-secondary">Cancelar</a>
        <button type="submit" class="btn btn-success" disabled="@(!proveedores.Any())">Comprar y recibir</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
