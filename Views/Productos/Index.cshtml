@model IEnumerable<ERPConcesionario.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Productos</h1>
    <a asp-action="Create" class="btn btn-primary">Nuevo Producto</a>
</div>

<table class="table table-bordered table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Código</th>
            <th>Nombre</th>
            <th>Marca</th>
            <th>Tipo</th>
            <th>Precio</th>
            <th>IVA</th>
            <th>Estado</th>
            <th style="width: 180px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CodigoProducto</td>
                <td>@item.Nombre</td>
                <td>@item.Marca</td>
                <td>@item.TipoProducto</td>
                <td>@item.PrecioVenta</td>
                <td>@item.IVA</td>
                <td>@item.EstadoProducto</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.IdProducto" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.IdProducto" class="btn btn-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>