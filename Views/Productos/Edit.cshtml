@model ERPConcesionario.Models.Producto

@{
    ViewData["Title"] = "Editar Producto";
}

<h1>Editar Producto</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="IdProducto" />

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="IdCategoriaProducto" class="form-label"></label>
            <input asp-for="IdCategoriaProducto" class="form-control" />
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="CodigoProducto" class="form-label"></label>
            <input asp-for="CodigoProducto" class="form-control" />
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="CodigoBarras" class="form-label"></label>
            <input asp-for="CodigoBarras" class="form-control" />
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="Nombre" class="form-label"></label>
            <input asp-for="Nombre" class="form-control" />
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="Marca" class="form-label"></label>
            <input asp-for="Marca" class="form-control" />
        </div>

        <div class="col-md-12 mb-3">
            <label asp-for="Descripcion" class="form-label"></label>
            <textarea asp-for="Descripcion" class="form-control"></textarea>
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="UnidadMedida" class="form-label"></label>
            <input asp-for="UnidadMedida" class="form-control" />
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="TipoProducto" class="form-label"></label>
            <select asp-for="TipoProducto" class="form-control">
                <option value="REPUESTO">REPUESTO</option>
                <option value="ACCESORIO">ACCESORIO</option>
                <option value="SERVICIO">SERVICIO</option>
                <option value="CONSUMIBLE">CONSUMIBLE</option>
            </select>
        </div>

        <div class="col-md-4 mb-3 d-flex align-items-center">
            <div class="form-check mt-4">
                <input asp-for="AfectaInventario" class="form-check-input" />
                <label asp-for="AfectaInventario" class="form-check-label"></label>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="StockMinimo" class="form-label"></label>
            <input asp-for="StockMinimo" class="form-control" />
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="StockMaximo" class="form-label"></label>
            <input asp-for="StockMaximo" class="form-control" />
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="CostoPromedio" class="form-label"></label>
            <input asp-for="CostoPromedio" class="form-control" />
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="PrecioVenta" class="form-label"></label>
            <input asp-for="PrecioVenta" class="form-control" />
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="IVA" class="form-label"></label>
            <input asp-for="IVA" class="form-control" />
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="EstadoProducto" class="form-label"></label>
            <select asp-for="EstadoProducto" class="form-control">
                <option value="ACTIVO">ACTIVO</option>
                <option value="INACTIVO">INACTIVO</option>
                <option value="DESCONTINUADO">DESCONTINUADO</option>
            </select>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Actualizar</button>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</form>