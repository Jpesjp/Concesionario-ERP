@model ERPConcesionario.Models.Empleado

@{
    ViewData["Title"] = "Eliminar Empleado";
}

<h1>Eliminar Empleado</h1>

<div class="alert alert-warning">
    ¿Estás seguro de que deseas eliminar este empleado?
</div>

<dl class="row">
    <dt class="col-sm-3">Código</dt>
    <dd class="col-sm-9">@Model.CodigoEmpleado</dd>

    <dt class="col-sm-3">Nombre</dt>
    <dd class="col-sm-9">@Model.PrimerNombre @Model.PrimerApellido</dd>

    <dt class="col-sm-3">Documento</dt>
    <dd class="col-sm-9">@Model.NumeroDocumento</dd>

    <dt class="col-sm-3">Teléfono</dt>
    <dd class="col-sm-9">@Model.TelefonoPersonal</dd>

    <dt class="col-sm-3">Estado</dt>
    <dd class="col-sm-9">@Model.EstadoEmpleado</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="IdEmpleado" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>