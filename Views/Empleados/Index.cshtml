@model IEnumerable<ERPConcesionario.Models.Empleado>

@{
    ViewData["Title"] = "Empleados";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Empleados</h1>
    <a asp-action="Create" class="btn btn-primary">Nuevo Empleado</a>
</div>

<table class="table table-bordered table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Código</th>
            <th>Nombre</th>
            <th>Documento</th>
            <th>Teléfono</th>
            <th>Cargo ID</th>
            <th>Salario</th>
            <th>Estado</th>
            <th style="width: 180px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CodigoEmpleado</td>
                <td>@item.PrimerNombre @item.SegundoNombre @item.PrimerApellido @item.SegundoApellido</td>
                <td>@item.TipoDocumento - @item.NumeroDocumento</td>
                <td>@item.TelefonoPersonal</td>
                <td>@item.IdCargo</td>
                <td>@item.SalarioBase</td>
                <td>@item.EstadoEmpleado</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.IdEmpleado" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.IdEmpleado" class="btn btn-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>