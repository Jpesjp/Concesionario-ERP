@model ERPConcesionario.Models.Proveedor

@{
    ViewData["Title"] = "Eliminar Proveedor";
}

<h1>Eliminar Proveedor</h1>

<div class="alert alert-warning">
    ¿Estás seguro de que deseas eliminar este proveedor?
</div>

<dl class="row">
    <dt class="col-sm-3">Código</dt>
    <dd class="col-sm-9">@Model.CodigoProveedor</dd>

    <dt class="col-sm-3">Razón Social</dt>
    <dd class="col-sm-9">@Model.RazonSocial</dd>

    <dt class="col-sm-3">Documento</dt>
    <dd class="col-sm-9">@Model.NumeroDocumento</dd>

    <dt class="col-sm-3">Teléfono</dt>
    <dd class="col-sm-9">@Model.Telefono</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="IdProveedor" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>