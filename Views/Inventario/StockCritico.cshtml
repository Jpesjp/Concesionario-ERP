@model IEnumerable<ERPConcesionario.Models.StockCriticoViewModel>

@{
    ViewData["Title"] = "Stock Critico";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="mb-1">Alerta de Stock Critico</h1>
        <p class="text-muted mb-0">Productos cuyo stock actual esta por debajo o igual al minimo permitido.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a asp-controller="Compras" asp-action="Index" class="btn btn-success">Compras</a>
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-dark">Dashboard</a>
        <a asp-controller="Inventario" asp-action="Index" class="btn btn-secondary">Volver</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-success shadow-sm">
        No hay productos en estado critico. El inventario esta en condiciones normales.
    </div>
}
else
{
    <div class="alert alert-warning shadow-sm">
        Se encontraron <strong>@Model.Count()</strong> registros en stock critico.
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Codigo</th>
                            <th>Producto</th>
                            <th>Stock Actual</th>
                            <th>Stock Minimo</th>
                            <th>Almacen</th>
                            <th>Ubicacion</th>
                            <th>Precio Venta</th>
                            <th>Compra sugerida</th>
                            <th>Estado</th>
                            <th style="width: 230px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="@(item.StockActual == 0 ? "table-danger" : "table-warning")">
                                <td>@item.CodigoProducto</td>
                                <td>@item.NombreProducto</td>
                                <td>@item.StockActual</td>
                                <td>@item.StockMinimo</td>
                                <td>@item.Almacen</td>
                                <td>@item.Ubicacion</td>
                                <td>@item.PrecioVenta.ToString("N0")</td>
                                <td>@item.CantidadSugerida</td>
                                <td>
                                    <span class="badge @(item.StockActual == 0 ? "bg-danger" : "bg-warning text-dark")">
                                        @item.EstadoAlerta
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex flex-wrap gap-2">
                                        <a asp-controller="Compras" asp-action="ComprarStockCritico" asp-route-id="@item.IdInventarioProducto" class="btn btn-success btn-sm">
                                            Comprar
                                        </a>
                                        <form asp-controller="Compras" asp-action="GenerarBorradorStockCritico" asp-route-id="@item.IdInventarioProducto" method="post">
                                            <button type="submit" class="btn btn-outline-primary btn-sm">Generar OC</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
