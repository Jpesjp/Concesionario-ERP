@{
    ViewData["Title"] = "Inventario";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Inventario</h1>
        <p class="text-muted mb-0">Gestión general de inventario del concesionario.</p>
    </div>
    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-dark">Dashboard</a>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-4 h-100">
            <div class="card-body">
                <h4>Alerta de Stock Crítico</h4>
                <p class="text-muted">
                    Consulta productos cuyo stock actual está por debajo del umbral mínimo.
                </p>
                <a asp-action="StockCritico" class="btn btn-warning">Ver alerta</a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-4 h-100">
            <div class="card-body">
                <h4>Módulo de Inventario</h4>
                <p class="text-muted">
                    Aquí luego podremos agregar movimientos, existencias por almacén, kardex y alertas adicionales.
                </p>
                <a asp-controller="Productos" asp-action="Index" class="btn btn-primary">Ir a Productos</a>
            </div>
        </div>
    </div>
</div>